<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.*?>


<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.DealerController"
      stylesheets="@/view/style.css"
      alignment="CENTER">

      <HBox alignment="CENTER" spacing="20">
            <ImageView fitWidth="140" preserveRatio="true" onMouseClicked="#handleMainDeck">
                  <image>
                        <Image url="@image/deck.png"/>
                  </image>
            </ImageView>

            <ImageView fitWidth="140" preserveRatio="true" onMouseClicked="#handleSecondaryDeck">
                  <image>
                        <Image url="@image/deck.png"/>
                  </image>
            </ImageView>
      </HBox>

      <GridPane hgap="20" vgap="10">
            <Label text="Player 1:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Text fx:id="player1ScoreTxt" text="0" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Player 2:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <Text fx:id="player2ScoreTxt" text="0" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

            <Label text="Player 3:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Text fx:id="player3ScoreTxt" text="N/A" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Player 4:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            <Text fx:id="player4ScoreTxt" text="N/A" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

            <Button fx:id="callButton" text="Call" prefWidth="130" prefHeight="30" onAction="#handleCall"
                  GridPane.columnIndex="4" GridPane.rowIndex="0" GridPane.rowSpan="2"/>
      </GridPane>

      <HBox alignment="CENTER" spacing="0">
            <Button fx:id="dealButton" text="Deal" prefWidth="130" onAction="#handleDeal"/>
            <Button fx:id="playroundButton" text="Play Round" prefWidth="130" onAction="#handlePlayRound"/>
            <Button fx:id="exitButton" text="Exit" prefWidth="130" onAction="#handleExit"/>
      </HBox>

</VBox>

