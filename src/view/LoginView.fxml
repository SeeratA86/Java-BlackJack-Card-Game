<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<!--Note that this window is not complete!-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.LoginController"
      stylesheets="@/view/style.css"
      prefWidth="600.0" 
      alignment="CENTER">

        <GridPane hgap="20" vgap="10" styleClass="padding-large">

                <ImageView fitWidth="90"
                        preserveRatio="true"
                        GridPane.halignment="CENTER"
                        GridPane.columnIndex="0"
                        GridPane.rowIndex="0">
                        <image>
                                <Image url="@image/avatar.png"/>
                        </image>
                </ImageView>

                <ImageView fitWidth="90"
                        preserveRatio="true"
                        GridPane.halignment="CENTER"
                        GridPane.columnIndex="1"
                        GridPane.rowIndex="0">
                        <image>
                                <Image url="@image/avatar.png"/>
                        </image>
                </ImageView>

                <ImageView fitWidth="90"
                        preserveRatio="true"
                        GridPane.halignment="CENTER"
                        GridPane.columnIndex="2"
                        GridPane.rowIndex="0">
                        <image>
                                <Image url="@image/avatar.png"/>
                        </image>
                </ImageView>

                <ImageView fitWidth="90"
                        preserveRatio="true"
                        GridPane.halignment="CENTER"
                        GridPane.columnIndex="3"
                        GridPane.rowIndex="0">
                        <image>
                                <Image url="@image/avatar.png"/>
                        </image>
                </ImageView>
        
        <TextField GridPane.halignment="CENTER" 
                GridPane.columnIndex="0" 
                GridPane.rowIndex="1" 
                fx:id="player1Tf"/>

        <TextField GridPane.halignment="CENTER" 
                GridPane.columnIndex="1" 
                GridPane.rowIndex="1" 
                fx:id="player2Tf"/>

        <TextField GridPane.halignment="CENTER" 
                GridPane.columnIndex="2" 
                GridPane.rowIndex="1" 
                fx:id="player3Tf"/>

        <TextField GridPane.halignment="CENTER" 
                GridPane.columnIndex="3" 
                GridPane.rowIndex="1"
                fx:id="player4Tf"/>

        </GridPane>

    <Button maxWidth="Infinity" 
            text="Start Game" 
            onAction="#handleStart"/>

</VBox>
